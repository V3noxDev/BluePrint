{
  "sort_order": 0,
  "name": "GeyserMC",
  "icon_url": "https://geysermc.org/img/apple-touch-icon.png",
  "category": "Plugins",
  "description": "Permite jogadores <strong>Bedrock</strong> entrarem no seu servidor <strong>Java</strong>.",
  "full_description": "<p>Instala o <strong>GeyserMC</strong> e o <strong>Floodgate</strong> automaticamente.</p><p>Após instalar, <strong>reinicie o servidor manualmente</strong>.</p><p>Antes de instalar, crie uma allocation na aba <strong>Rede</strong> para a porta Bedrock (ex: 19132).</p>",
  "password": null,
  "password_description": null,
  "version": "1.2.0",
  "author": "BluePrint",
  "enabled": true,
  "variables": [
    {
      "sort_order": 0,
      "name": "Porta Bedrock",
      "env_variable": "bedrock_port",
      "description": "Porta UDP para jogadores Bedrock. Deve estar criada na aba Rede do servidor.",
      "default_value": "19132",
      "rules": "required|integer|min:1|max:65535",
      "selectable": true
    },
    {
      "sort_order": 1,
      "name": "Tipo do GeyserMC",
      "env_variable": "geyser_type",
      "description": "Plataforma do seu servidor.",
      "default_value": "spigot",
      "rules": "required|string|in:spigot,bungeecord,velocity",
      "selectable": true
    }
  ],
  "steps": [
    {
      "sort_order": 0,
      "action": "mkdir",
      "file_path": "plugins",
      "content": null
    },
    {
      "sort_order": 1,
      "action": "pull",
      "file_path": "plugins/geyser-{{ $geyser_type }}.jar",
      "content": "https://download.geysermc.org/v2/projects/geyser/versions/latest/builds/latest/downloads/{{ $geyser_type }}"
    },
    {
      "sort_order": 2,
      "action": "pull",
      "file_path": "plugins/floodgate-{{ $geyser_type }}.jar",
      "content": "https://download.geysermc.org/v2/projects/floodgate/versions/latest/builds/latest/downloads/{{ $geyser_type }}"
    },
    {
      "sort_order": 3,
      "action": "write",
      "file_path": "plugins/geyser-{{ $geyser_type }}/config.yml",
      "content": "# Gerado pelo Template Installer\nbedrock:\n  port: {{ $bedrock_port }}\n  clone-remote-port: false\nremote:\n  address: 127.0.0.1\n  port: {{ $server_port }}\n  auth-type: floodgate\n"
    }
  ]
}
